---
# Example only. Do not apply this file directly in GitOps.
# ansible/argocd/argocd_add_app.yml creates these secrets at deploy time.
apiVersion: v1
kind: Secret
metadata:
  name: immich-postgres-secret
  namespace: aesthetic-hub
type: Opaque
stringData:
  password: REPLACE_AT_DEPLOY_TIME
---
apiVersion: v1
kind: Secret
metadata:
  name: data-pipeline-postgres-secret
  namespace: aesthetic-hub
type: Opaque
stringData:
  password: REPLACE_AT_DEPLOY_TIME
  immich_readonly_password: REPLACE_AT_DEPLOY_TIME
